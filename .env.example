# Integra Sales — пример переменных окружения
# Скопируйте в .env и заполните значения

# Google Sheets
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json
# Таблица физиков (звонки / основной дашборд)
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/...
# Таблица юриков: список в CRM = импорт из этого URL (кнопка «Подтянуть из таблицы» или POST /api/legal/sync / cron)
GOOGLE_LEGAL_SHEET_URL=https://docs.google.com/spreadsheets/d/...

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# База данных
DATABASE_PATH=integra.db

# Сессия (сгенерируйте случайный ключ)
SESSION_SECRET=change-me-to-random-string

# URL приложения (на сервере — ваш домен)
APP_BASE_URL=https://your-domain.com
LOGIN_LINK_URL=https://your-domain.com

# --- Почта (вкладка «Почта»): приложение подключается к SMTP как обычный почтовый клиент. ---
# Корпоративная почта: возьми в IT/hosting параметры «исходящая почта» (SMTP-сервер, порт, SSL/TLS).
# Часто порт 465 + SSL или 587 + STARTTLS — смотри инструкцию провайдера.
#
# Gmail / Google Workspace:
#   Не используй обычный пароль аккаунта. В Google: безопасность → двухэтапная → пароли приложений →
#   создать пароль для «Почта» и подставить его в SMTP_PASSWORD. Хост: smtp.gmail.com
#
# SMTP_USER / SMTP_FROM обычно совпадают с рабочим email. SMTP_FROM_NAME — как видят отправителя.
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SSL=0
# SMTP_USER=you@company.ru
# SMTP_PASSWORD=
# SMTP_FROM=you@company.ru
# SMTP_FROM_NAME=Integra Sales
