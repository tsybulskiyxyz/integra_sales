# Integra Sales — пример переменных окружения
# Скопируйте в .env и заполните значения

# Google Sheets
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/...

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# База данных
DATABASE_PATH=integra.db

# Сессия (сгенерируйте случайный ключ)
SESSION_SECRET=change-me-to-random-string

# URL приложения (на сервере — ваш домен)
APP_BASE_URL=https://your-domain.com
LOGIN_LINK_URL=https://your-domain.com
