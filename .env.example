# Integra Sales — пример переменных окружения
# Скопируйте в .env и заполните значения

# Google Sheets (физики — URL в .env; юрики — ссылка сохраняется в CRM в интерфейсе)
GOOGLE_CREDENTIALS_PATH=credentials/service_account.json
GOOGLE_SHEET_URL=https://docs.google.com/spreadsheets/d/...

# Zvonok (прозвон) — см. integrations/zvonok.py и документацию ЛК
# ZVONOK_API_KEY=
# ZVONOK_CAMPAIGN_ID=
# ZVONOK_API_URL=https://api.zvonok.com
# ZVONOK_PHONES_ENDPOINT=/v2/phones/tasks
# ZVONOK_USE_JSON=1

# eLama (аудитории / ретаргетинг) — см. integrations/elama.py
# ELAMA_ACCESS_TOKEN=
# ELAMA_AUDIENCE_ID=
# ELAMA_API_BASE=https://api.elama.global
# ELAMA_CONTACTS_ENDPOINT=/v1/audience/contacts

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# База данных
DATABASE_PATH=integra.db

# Сессия (сгенерируйте случайный ключ)
SESSION_SECRET=change-me-to-random-string

# URL приложения (на сервере — ваш домен)
APP_BASE_URL=https://your-domain.com
LOGIN_LINK_URL=https://your-domain.com

# SMTP — рассылка вкладка «Почта» (отправка с вашего ящика)
# Примеры хостов: smtp.gmail.com | smtp.yandex.ru | smtp.mail.ru
# SMTP_SSL=1 и порт 465 — или порт 587 без SSL (STARTTLS), по умолчанию 587 + STARTTLS
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=your@mail.ru
# SMTP_PASSWORD=
# SMTP_FROM=
# SMTP_FROM_NAME=Integra Sales
# SMTP_SSL=0
